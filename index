<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ocean Misst | Joyería de Alta Gama</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@200;400&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --fondo: #020d14; /* Azul abisal casi negro */
            --oro: #d4af37;   /* Oro metálico */
            --blanco: #f8f9fa;
            --texto-suave: #bdc3c7;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--fondo);
            color: var(--blanco);
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
        }

        /* Navegación */
        nav {
            position: fixed;
            top: 0; width: 100%;
            padding: 30px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            background: linear-gradient(to bottom, var(--fondo), transparent);
        }

        .logo {
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            letter-spacing: 6px;
            color: var(--oro);
            text-decoration: none;
        }

        /* Hero Section */
        header {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            background: radial-gradient(circle, rgba(10,35,51,1) 0%, rgba(2,13,20,1) 100%);
            padding: 20px;
        }

        .hero-title {
            font-family: 'Cinzel', serif;
            font-size: clamp(2.5rem, 8vw, 5rem);
            letter-spacing: 15px;
            margin-bottom: 20px;
            text-transform: uppercase;
            color: var(--blanco);
        }

        .hero-subtitle {
            font-size: 1rem;
            letter-spacing: 5px;
            text-transform: uppercase;
            color: var(--oro);
            margin-bottom: 40px;
        }

        /* Botón de Lujo */
        .btn-luxury {
            padding: 18px 45px;
            background: transparent;
            border: 1px solid var(--oro);
            color: var(--oro);
            text-transform: uppercase;
            letter-spacing: 4px;
            cursor: pointer;
            transition: all 0.5s ease;
            font-size: 0.8rem;
        }

        .btn-luxury:hover {
            background: var(--oro);
            color: var(--fondo);
            box-shadow: 0 0 30px rgba(212, 175, 55, 0.3);
        }

        /* Grid de Colección */
        .collection {
            padding: 100px 10%;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 50px;
        }

        .card {
            border: 1px solid #0a2333;
            padding: 20px;
            text-align: center;
            transition: 0.6s;
            background: #04121a;
        }

        .card:hover {
            border-color: var(--oro);
            transform: translateY(-10px);
        }

        .card-img {
            width: 100%;
            height: 350px;
            background: #081a26; /* Simulación de imagen */
            margin-bottom: 20px;
            position: relative;
        }

        /* Animación suave */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            transition: 1s all ease;
        }

        .visible {
            opacity: 1;
            transform: translateY(0);
        }

        footer {
            padding: 80px;
            text-align: center;
            font-size: 0.7rem;
            letter-spacing: 3px;
            border-top: 1px solid #0a2333;
            color: var(--texto-suave);
        }
    </style>
</head>
<body>

    <nav>
        <a href="#" class="logo">OCEAN MISST</a>
        <div style="font-size: 0.7rem; letter-spacing: 2px;">ATELIER PRIVÉ</div>
    </nav>

    <header>
        <h1 class="hero-title">Ocean Misst</h1>
        <p class="hero-subtitle">La Alta Joyería del Abismo</p>
        <button class="btn-luxury" onclick="scrollToCollection()">Ver Colección</button>
    </header>

    <section class="collection" id="coleccion">
        <div class="card fade-in">
            <div class="card-img"></div>
            <h3 style="font-family: 'Cinzel'; color: var(--oro);">Collar Poseidón</h3>
            <p style="font-size: 0.8rem; margin-top: 10px; color: var(--texto-suave);">$85,000 USD</p>
        </div>
        <div class="card fade-in">
            <div class="card-img"></div>
            <h3 style="font-family: 'Cinzel'; color: var(--oro);">Anillo Perla Negra</h3>
            <p style="font-size: 0.8rem; margin-top: 10px; color: var(--texto-suave);">$42,000 USD</p>
        </div>
        <div class="card fade-in">
            <div class="card-img"></div>
            <h3 style="font-family: 'Cinzel'; color: var(--oro);">Brazalete Coral Oro</h3>
            <p style="font-size: 0.8rem; margin-top: 10px; color: var(--texto-suave);">$115,000 USD</p>
        </div>
    </section>

    <footer>
        &copy; 2026 OCEAN MISST. GINEBRA | MÓNACO | NUEVA YORK
    </footer>

    <script>
        // Función para scroll suave
        function scrollToCollection() {
            document.getElementById('coleccion').scrollIntoView({ behavior: 'smooth' });
        }

        // Observador para animaciones al hacer scroll
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    </script>
</body>
</html>
